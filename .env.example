# Kopieer dit bestand naar .env en vul de waarden in.
# Commit .env NOOIT naar Git — het staat in .gitignore.

# PostgreSQL-verbinding (schrijfrechten, voor schema + laadscripts)
DATABASE_URL=postgresql://vgbc_user:kies_een_sterk_wachtwoord@localhost:5432/vgbc_poc

# PostgreSQL-verbinding voor de AI-agent (read-only rol)
AGENT_DATABASE_URL=postgresql://vgbc_agent:agent_readonly_pw@localhost:5432/vgbc_poc

# Anthropic API-sleutel — haal op via https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# LLM-model: gebruik claude-sonnet-4-6 voor kwaliteit, claude-haiku-4-5-20251001 voor snelheid/kosten
LLM_MODEL=claude-sonnet-4-6

# Streamlit-poort (optioneel, standaard 8501)
# STREAMLIT_PORT=8501
